# Per-Dockerfile .dockerignore for the sign extension (TypeScript build).
# Build context is the sign extension dir itself (extensions/sign/). The build
# only needs typescript/ (the extension source) — tee-node is cloned from
# GitHub during the build, and node_modules/dist are regenerated by `npm ci` +
# `npm run build`, so neither the host's nor anything else enters the context.

# Ignore everything, then re-include just the typescript extension.
*
!typescript/

# Regenerated in the build — never ship the host's copies
typescript/node_modules
typescript/dist
typescript/build

# IDE / VCS / OS noise
**/.git
**/.idea
**/.vscode
**/.DS_Store
**/Thumbs.db
**/.claude

# Logs / temp files
**/*.log
**/*.tmp
**/*.swp
**/*.swo

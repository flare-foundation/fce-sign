# Language implementation to run (go, python, or typescript)
LANGUAGE=go

# Funded Coston2 private key (hex, no 0x prefix)
PRIVATE_KEY="28f6e787e2d1dc9b8e793ac9211b40ff22e0c9bc828634ebc18cfd885a48e81c"

# Initial owner address (derived from PRIVATE_KEY)
INITIAL_OWNER="0x07DdcCB521171eFE3939a61971439576A86A8c31"

# Extension ID (set after registering the extension in step 2)
EXTENSION_ID="0x<64-hex-chars>"

# InstructionSender contract address (set after deploying the contract in step 1)
INSTRUCTION_SENDER="0x0x76A76334e1d793dD6C6f95DfcFFefB81394aba87"

# Public tunnel URL (set after starting cloudflared/ngrok in step 0)
TUNNEL_URL="https://<your-tunnel-url>"

# Fee paid per instruction in wei (default: 1000000000000 = 0.000001 ETH)
# Increase if you get a FeeTooLow revert.
FEE_WEI=1000000000000

# Chain RPC URL
CHAIN_URL=https://coston2-api.flare.network/ext/C/rpc

# Path to Coston2 deployed contract addresses
ADDRESSES_FILE=./config/coston2/deployed-addresses.json

# Normal/FTDC proxy URL on Coston2 (for TEE registration)
NORMAL_PROXY_URL=https://tee-proxy-coston2-1.flare.rocks

# Must be false on live networks
LOCAL_MODE=false

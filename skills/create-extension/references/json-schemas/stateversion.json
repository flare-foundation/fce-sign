{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StateVersion",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "stateVersion": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$", "description": "bytes32 encoded as go-ethereum common.Hash (always 0x-prefixed, 66 chars total)" },
    "state": { "type": "string", "pattern": "^(0x)?[0-9a-fA-F]*$" }
  },
  "required": ["stateVersion", "state"],
  "examples": [
    {
      "stateVersion": "0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef",
      "state": "0xdeadbeef"
    }
  ]
}

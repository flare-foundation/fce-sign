# sign-extension — environment template
#
# Copy this file to .env (or to .env.coston / .env.coston2 and switch with
# `./scripts/use-chain.sh <chain>`). The active .env is loaded by every script.

# --- Keys -------------------------------------------------------------------
# Funded private key used by deploy + register tools (no 0x prefix).
# Must hold C2FLR/CFLR on the target chain — fund at https://faucet.flare.network/
DEPLOYMENT_PRIVATE_KEY="<your-funded-private-key-hex-no-0x>"

# Address derived from DEPLOYMENT_PRIVATE_KEY — becomes the extension owner.
INITIAL_OWNER="0x<your-address>"

# Funded private key for the local ext-proxy signing (only used in --local mode).
# On testnet, devops's hosted proxy uses devops's own key; this can stay at the
# Hardhat dev default for local-stack debugging.
PROXY_PRIVATE_KEY="983760a4ebf75b2ac3a93531168a0f225d01e5dc6e3568adbd46233ba1fb4fa4"

# --- Chain ------------------------------------------------------------------
# RPC URL. Coston: https://coston-api.flare.network/ext/C/rpc
# Coston2:       https://coston2-api.flare.network/ext/C/rpc
# Local devnet:  http://127.0.0.1:8545
CHAIN_URL=http://127.0.0.1:8545

# coston | coston2 | local — also used by scripts to pick the addresses file.
CHAIN=local

# Path to the on-chain contract registry for this chain (array+Diamond format).
ADDRESSES_FILE=./config/coston2/deployed-addresses.json

# true for local devnet, false for Coston/Coston2.
LOCAL_MODE=true

# Attestation mode. true on local devnet (test code hash), false on a real GCP
# Confidential Space VM. Must agree with the TEE binary's MODE env (1=simulated,
# 0=production attestation).
SIMULATED_TEE=true

# --- Proxies ----------------------------------------------------------------
# Extension proxy URL — the host that exposes /info and /action. For local
# Docker compose this is auto-detected (http://localhost:6674). For Coston/Coston2,
# devops provides this URL.
# EXT_PROXY_URL=http://localhost:6674

# Normal/FTDC proxy URL on the target chain. Used during register-tee for the
# availability check.
# Coston:  https://tee-proxy-coston-1.flare.rocks
# Coston2: https://tee-proxy-coston2-1.flare.rocks
NORMAL_PROXY_URL=http://localhost:6662

# --- Docker -----------------------------------------------------------------
# Docker image registry. Leave commented to use the locally-built local/tee-proxy
# image (see scripts/start-services.sh). Set to a remote registry to pull instead.
# REGISTRY=registry.gitlab.com/flarenetwork/tee/e2e

# Extension language. Picks which Dockerfile docker-compose builds for the
# extension-tee service: go|python|typescript. The Go path is the most
# thoroughly reproducible; python/typescript aim for same-machine determinism
# (see REPRODUCIBILITY.md).
LANGUAGE=go

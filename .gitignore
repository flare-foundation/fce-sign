.agents/
.claude/

# Go
vendor/

# Environment files (contain secrets) — keep .env.example
.env
.env.*
!.env.example

# Coston/Coston2 proxy configs (contain DB credentials)
config/proxy/extension_proxy.toml
config/proxy/extension_proxy.coston.toml
config/proxy/extension_proxy.coston.docker.toml
config/proxy/extension_proxy.coston2.toml
config/proxy/extension_proxy.coston2.docker.toml

# Generated by pre-build.sh / post-build.sh
config/extension.env
config/register-tee.state
config/**/*.log

# Build output
out/
cache/

# Generated contract bindings (produced by scripts/generate-bindings.sh)
go/tools/pkg/contracts/*/autogen.go
go/tools/pkg/contracts/*/*.abi
go/tools/pkg/contracts/*/*.bin

# Compiled Go binaries
go/tools/start-*
go/tools/allow-*
go/tools/deploy-*
go/tools/register-*
go/tools/run-*
go/tools/*.exe
go/tools/check-tee-state*
!go/tools/cmd/check-tee-state/

# Hand-off image tarballs (produced by scripts/build-image.sh)
sign-extension-*.tar

# Private deployment notes
DEPLOYMENT.md
notes/

# Python
__pycache__/
*.pyc
.venv/

# TypeScript / Node
node_modules/
dist/

# OS
.DS_Store
